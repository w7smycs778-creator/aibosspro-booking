# ─── Google Calendar ─────────────────────────────────────────────────
# Full JSON of the service account key file (stringify the file contents)
# Example: cat service-account.json | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"booking@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The service account email (found inside GOOGLE_SERVICE_ACCOUNT_JSON → client_email)
# Share your Google Calendar with this address (Make changes to events permission)
GOOGLE_CALENDAR_EMAIL=booking@your-project.iam.gserviceaccount.com

# The calendar ID to write appointments into
# Find it in Google Calendar → Settings → Specific calendar → Calendar ID
CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ─── WhatsApp webhook ────────────────────────────────────────────────
# POST endpoint that receives booking payload and sends a WhatsApp confirmation
# Leave empty to skip (booking still works, just no WhatsApp message)
WHATSAPP_WEBHOOK_URL=https://your-n8n-instance.com/webhook/booking-confirm

# ─── Server ──────────────────────────────────────────────────────────
PORT=3001
